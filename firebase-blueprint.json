{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "A cooperative member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "memberId": { "type": "string" },
        "joinDate": { "type": "string", "format": "date-time" },
        "isChild": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["name", "phone", "memberId", "joinDate"]
    },
    "Account": {
      "title": "Account",
      "description": "A member's specific account (Share, Savings, etc.)",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["SHARE", "SAVINGS", "DPS", "FDR", "CHILD_SAVINGS", "LOAN"] },
        "balance": { "type": "number" },
        "lastInterestCalculated": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "accountId": { "type": "string" },
        "type": { "type": "string", "enum": ["DEPOSIT", "WITHDRAWAL", "INTEREST", "LOAN_REPAYMENT", "LOAN_DISBURSE"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Store member profiles"
    },
    "/members/{memberId}/accounts/{accountId}": {
      "schema": "Account",
      "description": "Store individual accounts for a member"
    },
    "/members/{memberId}/transactions/{txnId}": {
      "schema": "Transaction",
      "description": "Store transaction logs for a member"
    }
  }
}
